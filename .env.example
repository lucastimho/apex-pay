# ─── APEX-Pay Environment Configuration ─────────────────────────────────────
# Copy to .env and fill in real values for production.

# Database — Least Privilege scoped connections (Supabase / PostgreSQL)
DB_GATEWAY_DSN=postgresql+asyncpg://apex_gateway:change_me_gateway@localhost:5432/apex_pay
DB_AUDITOR_DSN=postgresql+asyncpg://apex_auditor:change_me_auditor@localhost:5432/apex_pay
DB_READONLY_DSN=postgresql+asyncpg://apex_readonly:change_me_readonly@localhost:5432/apex_pay
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=5

# Redis — async audit queue
REDIS_URL=redis://localhost:6379/0
REDIS_AUDIT_QUEUE_NAME=apex:audit_queue
REDIS_MAX_QUEUE_DEPTH=5000

# Security — token signing
SECURITY_HMAC_SECRET_KEY=replace-with-a-64-char-random-hex-string
SECURITY_TOKEN_TTL_SECONDS=300
SECURITY_JWT_ALGORITHM=HS256

# Rate Limiting
RATELIMIT_DEFAULT=60/minute
RATELIMIT_PER_AGENT=30/minute

# Pydantic Logfire — observability
LOGFIRE_TOKEN=                    # Leave empty for console-only output
LOGFIRE_SERVICE_NAME=apex-pay
LOGFIRE_ENVIRONMENT=development

# App
DEBUG=false
